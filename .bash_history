cat > server.js << 'EOF'
const express = require('express');
const http = require('http');
const { Server } = require('socket.io');
const path = require('path');
const fs = require('fs');
const cors = require('cors');
const app = express();
const server = http.createServer(app);
const io = new Server(server, { cors: { origin: "*" } });
app.use(cors());
app.use(express.json());
let users = {}; let otps = {};
let rooms = { 10001: { id: 10001, name: "Masti Night", seats: Array(8).fill(null) } };

app.post('/api/send-otp', (req,res)=>{
  const otp = Math.floor(100000+Math.random()*900000).toString();
  otps[req.body.phone]=otp;
  console.log(`\nOTP for ${req.body.phone} = ${otp}\n`);
  res.json({success:true, demo_otp:otp});
});
app.post('/api/verify-otp', (req,res)=>{
  const {phone, otp}=req.body;
  if(otps[phone]!==otp) return res.json({success:false});
  if(!users[phone]) users[phone]={id:'MT'+Date.now(), phone, wallet:1000};
  res.json({success:true, user:users[phone]});
});

const finalHTML = `<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Masti Tok</title><script src="/socket.io/socket.io.js"></script><script src="https://cdn.tailwindcss.com"></script></head><body class="bg-[#0f0f0f] text-white">
<div id="login" class="min-h-screen flex flex-col items-center justify-center p-6"><h1 class="text-4xl font-black mb-8 bg-gradient-to-r from-pink-500 to-purple-500 bg-clip-text text-transparent">MASTI TOK</h1><input id="phone" placeholder="Phone" class="w-full max-w-sm bg-[#1e1e1e] py-3 px-4 rounded-full"><button onclick="sendOtp()" class="w-full max-w-sm mt-3 bg-pink-600 py-3 rounded-full font-bold">Send OTP - See Termux</button><input id="otp" placeholder="OTP from Termux" class="w-full max-w-sm bg-[#1e1e1e] py-3 px-4 rounded-full mt-2"><button onclick="verifyOtp()" class="w-full max-w-sm mt-3 bg-white text-black py-3 rounded-full font-bold">Verify</button></div>
<div id="home" class="hidden p-4"><h2 class="font-bold mb-3">Live Rooms</h2><div onclick="joinRoom(10001)" class="bg-[#1e1e1e] p-4 rounded-2xl">Masti Night - 234 online - TAP TO JOIN</div></div>
<div id="room" class="hidden min-h-screen flex flex-col"><div class="p-4 flex justify-between"><span id="roomId"></span><button onclick="location.reload()" class="bg-[#222] px-3 py-1 rounded-full">Leave</button></div><div id="seats" class="grid grid-cols-4 gap-4 p-4"></div><div class="mt-auto p-3 bg-[#1a1a1a] flex gap-2"><input id="chatInput" class="flex-1 bg-[#222] rounded-full px-4 py-2"><button onclick="startGame()" class="bg-pink-600 px-4 py-2 rounded-full">Game</button></div><p id="gameResult" class="text-center text-pink-400 p-2"></p></div>
<script>
const socket=io();let myPhone='',currentRoom=null;
function sendOtp(){myPhone=document.getElementById('phone').value;fetch('/api/send-otp',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:myPhone})}).then(r=>r.json()).then(d=>{alert('OTP Termux e: '+d.demo_otp);document.getElementById('otp').value=d.demo_otp;});}
function verifyOtp(){const otp=document.getElementById('otp').value;fetch('/api/verify-otp',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:myPhone,otp})}).then(r=>r.json()).then(d=>{if(d.success){document.getElementById('login').classList.add('hidden');document.getElementById('home').classList.remove('hidden');}});}
function joinRoom(id){currentRoom=id;document.getElementById('roomId').innerText=id;document.getElementById('home').classList.add('hidden');document.getElementById('room').classList.remove('hidden');renderSeats(Array(8).fill(null));}
function renderSeats(seats){const c=document.getElementById('seats');c.innerHTML='';seats.forEach((s,i)=>{const d=document.createElement('div');d.className='w-16 h-16 rounded-full bg-[#1e1e1e] flex items-center justify-center border-2';if(s)d.className+=' border-pink-500';d.innerHTML=s?'<span class=text-xs>'+s.phone.slice(-4)+'</span>':'+';d.onclick=()=>{if(!s)socket.emit('take-seat',{roomId:currentRoom,seatIndex:i,phone:myPhone});};c.appendChild(d);});}
function startGame(){socket.emit('game-start',{roomId:currentRoom});}
socket.on('room-update',r=>renderSeats(r.seats));
socket.on('game-result',d=>document.getElementById('gameResult').innerText='Winner Seat '+(d.result.winnerSeat+1)+' Reward 500');
<\/script></body></html>`;

app.use((req,res)=>{
  const publicPath = path.join(__dirname,'public','index.html');
  if(fs.existsSync(publicPath)) res.sendFile(publicPath);
  else res.send(finalHTML);
});

io.on('connection',(socket)=>{
  socket.on('take-seat',(d)=>{
    let r=rooms[d.roomId]; if(!r) return;
    r.seats=r.seats.map(s=>s&&s.phone===d.phone?null:s);
    if(r.seats[d.seatIndex]===null) r.seats[d.seatIndex]={phone:d.phone};
    io.emit('room-update',r);
  });
  socket.on('game-start',(d)=>{ io.emit('game-result',{result:{winnerSeat:Math.floor(Math.random()*8)}}); });
});

server.listen(3000,'0.0.0.0',()=>console.log('MASTI TOK running http://localhost:3000'));
EOF

