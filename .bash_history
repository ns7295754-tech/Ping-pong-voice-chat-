const express=require('express');
const http=require('http');
const {Server}=require('socket.io');
const app=express();
const server=http.createServer(app);
const io=new Server(server,{cors:{origin:'*'}});
app.use(express.json());
let otps={},rooms={10001:{seats:Array(8).fill(null)}};
app.post('/api/send-otp',(req,res)=>{let o=''+Math.floor(100000+Math.random()*900000);otps[req.body.phone]=o;console.log('OTP='+o);res.json({success:true,demo_otp:o})});
app.post('/api/verify-otp',(req,res)=>{res.json({success:otps[req.body.phone]==req.body.otp})});
app.get('/',(req,res)=>{res.send('<h1 style="color:#ff3b8d;text-align:center;margin-top:50px;font-family:sans-serif">MASTI TOK IS LIVE</h1><p style="text-align:center"><a href="/app" style="color:white">Go to App</a></p>')});
app.get('/app',(req,res)=>{res.send(`<!DOCTYPE html><meta name=viewport content="width=device-width,initial-scale=1"><script src="/socket.io/socket.io.js"></script><style>body{background:#0a0a0f;color:#fff;font-family:sans-serif;text-align:center;padding:20px}.t{font-size:32px;font-weight:900;background:linear-gradient(90deg,#ff3b8d,#7b61ff);-webkit-background-clip:text;color:transparent}.seat{width:68px;height:68px;border-radius:50%;background:#1e1e2e;border:2px solid #333;display:inline-flex;align-items:center;justify-content:center;margin:6px}.seat.taken{border-color:#ff3b8d}</style><div class=t>MASTI TOK</div><input id=ph placeholder=Phone style="width:100%;max-width:350px;background:#1e1e2e;padding:12px;border-radius:20px;border:none;color:#fff;margin-top:20px"><br><button onclick="sendOtp()" style="width:100%;max-width:350px;background:#ff3b8d;padding:12px;border-radius:20px;border:none;margin-top:10px;color:#fff">Send OTP</button><br><input id=otp placeholder=OTP style="width:100%;max-width:350px;background:#1e1e2e;padding:12px;border-radius:20px;border:none;color:#fff;margin-top:10px"><br><button onclick="verifyOtp()" style="width:100%;max-width:350px;background:#fff;color:#000;padding:12px;border-radius:20px;border:none;margin-top:10px">Verify</button><div id=home style="display:none;margin-top:20px"><button onclick="joinRoom()" style="background:#1e1e2e;padding:16px;border-radius:16px;border:none;color:#fff;width:100%">TAP TO JOIN</button></div><div id=room style="display:none;margin-top:20px"><div id=seats></div><button onclick="socket.emit('game-start',{})" style="background:linear-gradient(90deg,#ff3b8d,#7b61ff);padding:12px 20px;border-radius:20px;border:none;color:#fff;margin-top:20px">Start Game</button></div><script>const socket=io();let myPh="";function sendOtp(){myPh=ph.value;fetch('/api/send-otp',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:myPh})}).then(r=>r.json()).then(d=>{alert(d.demo_otp);otp.value=d.demo_otp})}function verifyOtp(){fetch('/api/verify-otp',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:myPh,otp:otp.value})}).then(r=>r.json()).then(d=>{if(d.success)home.style.display='block'})}function joinRoom(){room.style.display='block';render(Array(8).fill(null))}function render(s){seats.innerHTML='';s.forEach((x,i)=>{let d=document.createElement('div');d.className='seat '+(x?'taken':'');d.innerHTML=x?x.phone.slice(-4):'+'+(i+1);d.onclick=()=>socket.emit('take-seat',{seatIndex:i,phone:myPh});seats.appendChild(d)})}socket.on('room-update',r=>render(r.seats));</script>`)});
io.on('connection',s=>{s.on('take-seat',d=>{let r=rooms[10001];r.seats=r.seats.map(x=>x&&x.phone==d.phone?null:x);if(!r.seats[d.seatIndex])r.seats[d.seatIndex]={phone:d.phone};io.emit('room-update',r)});});
server.listen(3000,'0.0.0.0',()=>console.log('RUNNING http://localhost:3000'));
END

